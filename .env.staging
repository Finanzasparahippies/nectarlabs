# Nectar Labs Staging Environment
DEBUG=True
SECRET_KEY=staging_secret_key_change_me_in_prod
ALLOWED_HOSTS=staging.nectarlabs.dev,localhost,127.0.0.1,nectar_backend_staging

# Database (Links to db-staging container)
DATABASE_URL=postgres://postgres:postgres@nectar-db-staging:5432/nectarlabs_staging

# API URLs
NEXT_PUBLIC_API_URL=http://staging.nectarlabs.localhost/api

# Security
CORS_ALLOWED_ORIGINS=http://staging.nectarlabs.localhost
CSRF_TRUSTED_ORIGINS=http://staging.nectarlabs.localhost
