# Nectar Labs Environment Configuration Template
DEBUG=True
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nectarlabs

# Cloudinary (Images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare R2 Storage (Documents)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_S3_ENDPOINT_URL=
R2_CUSTOM_DOMAIN=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email SMTP (Zoho / Default)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Nectar Labs <soporte@nectarlabs.dev>
EMAIL_SUPPORT=Nectar Labs Soporte <soporte@nectarlabs.dev>
EMAIL_NEWSLETTER=Nectar Labs <hola@nectarlabs.dev>
EMAIL_CONTACT=Nectar Labs <contacto@nectarlabs.dev>
EMAIL_BILLING=Nectar Labs Facturación <facturacion@nectarlabs.dev>

# Brevo SMTP Relay (Newsletter channel)
BREVO_EMAIL_HOST_USER=
BREVO_EMAIL_HOST_PASSWORD=

# Amazon SES SMTP Relay (Backup / Massive newsletter channel)
SES_EMAIL_HOST=email-smtp.us-east-2.amazonaws.com
SES_EMAIL_HOST_USER=
SES_EMAIL_HOST_PASSWORD=

# Frontend & API URLs
FRONTEND_URL=http://localhost:3000
INTERNAL_API_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Security / CORS & CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
